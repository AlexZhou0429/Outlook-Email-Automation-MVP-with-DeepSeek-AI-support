# Microsoft Entra app registration
# Use your tenant id for company/work account. Use "common" only for quick personal testing.
MS_TENANT_ID=YOUR_TENANT_ID
MS_CLIENT_ID=YOUR_PUBLIC_CLIENT_APP_ID

# LLM provider
# DeepSeek is OpenAI-SDK-compatible; keep the OpenAI Python package installed.
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=sk-...
AI_MODEL=deepseek-v4-flash

# Backward-compatible alternatives also work:
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# Runtime behavior
MAIL_FOLDER=AI Intake
MAX_MESSAGES=5
DRY_RUN=true
